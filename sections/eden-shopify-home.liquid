<section class="eden-hero eden-hero-approved">
  <div class="eden-hero-inner">
    <div>
      <p class="eden-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="eden-hero-actions"><a class="eden-button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a><a class="eden-button secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a></div>
      <div class="eden-hero-proof"><span>Model portfolios</span><span>Premium media</span><span>Black Card</span><span>Private closet</span></div>
    </div>
    <div class="eden-visual-panel">{% if section.settings.hero_image != blank %}{{ section.settings.hero_image | image_url: width: 1400 | image_tag: loading: 'eager', alt: section.settings.heading }}{% elsif section.settings.hero_fallback_url != blank %}<img src="{{ section.settings.hero_fallback_url | escape }}" alt="{{ section.settings.heading | escape }}" loading="eager">{% endif %}</div>
  </div>
</section>
{% assign female_blocks = section.blocks | where: 'type', 'female_model' %}{% assign male_blocks = section.blocks | where: 'type', 'male_model' %}{% assign faceless_blocks = section.blocks | where: 'type', 'faceless_offer' %}{% assign product_blocks = section.blocks | where: 'type', 'product_offer' %}
<section class="eden-section" id="ladies"><div class="eden-section-head"><div><p class="eden-eyebrow">Ladies</p><h2>Choose your model</h2></div><p>Select a model to view her portfolio, available media styles, and Black Card access options.</p></div><div class="eden-grid">{% for block in female_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'View portfolio', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/collections/ladies">View all ladies</a><a class="eden-button secondary" href="/pages/payment">Join Black Card</a></div></section>
<section class="eden-section eden-feature-band" id="gentlemen"><div class="eden-section-head"><div><p class="eden-eyebrow">Gentlemen</p><h2>Men's model portfolio</h2></div><p>Browse premium male models for lifestyle, editorial, creator campaigns, and private media access.</p></div><div class="eden-grid">{% for block in male_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'View portfolio', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/collections/gentlemen">View all gentlemen</a><a class="eden-button secondary" href="/pages/payment">Join Black Card</a></div></section>
<section class="eden-section" id="faceless"><div class="eden-section-head"><div><p class="eden-eyebrow">Faceless</p><h2>Content creator media</h2></div><p>Premium faceless media concepts for luxury visuals, product storytelling, and short-form creator content.</p></div><div class="eden-product-list">{% for block in faceless_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Explore media', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div></section>
<section class="eden-section eden-feature-band" id="black-card"><div class="eden-section-head"><div><p class="eden-eyebrow">Membership</p><h2>Black Card access</h2></div><p>Join Black Card to unlock private model media, premium drops, Eden's Closet access, and member-only digital experiences.</p></div><div class="eden-product-list">{% for block in product_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Membership', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/pages/payment">Open payment page</a><a class="eden-button secondary" href="/pages/edens-closet">Preview Eden's Closet</a></div></section>
{% schema %}
{"name":"Eden Shopify home","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Eden Skye Studios"},{"type":"text","id":"heading","label":"Heading","default":"Beauty. Influence. Impact."},{"type":"textarea","id":"subheading","label":"Subheading","default":"A premium digital model and media studio for model portfolios, private content drops, Black Card membership, and Eden's Closet access."},{"type":"image_picker","id":"hero_image","label":"Hero image"},{"type":"text","id":"hero_fallback_url","label":"Shopify CDN hero image URL"},{"type":"text","id":"primary_label","label":"Primary label","default":"Explore models"},{"type":"url","id":"primary_link","label":"Primary link"},{"type":"text","id":"secondary_label","label":"Secondary label","default":"Join Black Card"},{"type":"url","id":"secondary_link","label":"Secondary link"}],"blocks":[{"type":"female_model","name":"Lady model","settings":[{"type":"text","id":"title","label":"Name","default":"Alexis Voss"},{"type":"textarea","id":"text","label":"Description","default":"Premium editorial model with private portfolio media and member-only content drops."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"male_model","name":"Gentleman model","settings":[{"type":"text","id":"title","label":"Name","default":"Dante Cross"},{"type":"textarea","id":"text","label":"Description","default":"Premium male model portfolio for lifestyle, editorial, and member media access."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"faceless_offer","name":"Faceless offer","settings":[{"type":"text","id":"title","label":"Title","default":"Noir Diary"},{"type":"textarea","id":"text","label":"Description","default":"Luxury faceless content lane for premium digital media."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"product_offer","name":"Product offer","settings":[{"type":"text","id":"title","label":"Title","default":"Black Card"},{"type":"textarea","id":"text","label":"Description","default":"Premium membership for private model media, content drops, and Eden's Closet access."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Eden Shopify home"}]}
{% endschema %}

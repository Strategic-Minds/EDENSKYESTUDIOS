<section class="eden-hero eden-hero-approved">
  <div class="eden-hero-inner">
    <div>
      <p class="eden-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="eden-hero-actions"><a class="eden-button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a><a class="eden-button secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a></div>
      <div class="eden-hero-proof"><span>10 ladies</span><span>5 gentlemen</span><span>Black Card</span><span>Xyla-ready</span></div>
    </div>
    <div class="eden-visual-panel">{% if section.settings.hero_image != blank %}{{ section.settings.hero_image | image_url: width: 1400 | image_tag: loading: 'eager', alt: section.settings.heading }}{% elsif section.settings.hero_fallback_url != blank %}<img src="{{ section.settings.hero_fallback_url | escape }}" alt="{{ section.settings.heading | escape }}" loading="eager">{% endif %}</div>
  </div>
</section>
{% assign female_blocks = section.blocks | where: 'type', 'female_model' %}{% assign male_blocks = section.blocks | where: 'type', 'male_model' %}{% assign faceless_blocks = section.blocks | where: 'type', 'faceless_offer' %}{% assign product_blocks = section.blocks | where: 'type', 'product_offer' %}
<section class="eden-section" id="ladies"><div class="eden-section-head"><div><p class="eden-eyebrow">Ladies</p><h2>Ladies of Eden Skye</h2></div><p>Approved premium model roster for Shopify, Black Card, Xyla video drafts, social automation, and member discovery.</p></div><div class="eden-grid">{% for block in female_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Lady model', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/collections/ladies">Open Ladies page</a><a class="eden-button secondary" href="/pages/model-portfolio">View portfolio</a></div></section>
<section class="eden-section eden-feature-band" id="gentlemen"><div class="eden-section-head"><div><p class="eden-eyebrow">Gentlemen</p><h2>Gentlemen of Eden Skye</h2></div><p>Five premium male models for lifestyle, fashion, Black Card campaigns, product content, and video automation.</p></div><div class="eden-grid">{% for block in male_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Gentleman model', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/collections/gentlemen">Open Gentlemen page</a><a class="eden-button secondary" href="/pages/payment">Black Card access</a></div></section>
<section class="eden-section" id="faceless"><div class="eden-section-head"><div><p class="eden-eyebrow">Faceless</p><h2>Content creator engines</h2></div><p>Premium faceless content lanes for Xyla AI, Shopify product storytelling, short-form video, and social draft automation.</p></div><div class="eden-product-list">{% for block in faceless_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Faceless lane', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div></section>
<section class="eden-section eden-feature-band" id="black-card"><div class="eden-section-head"><div><p class="eden-eyebrow">Commerce</p><h2>Black Card and products</h2></div><p>Shopify-ready premium offer surfaces for Black Card, AI model content packs, Xyla video drafts, and approval-gated automation.</p></div><div class="eden-product-list">{% for block in product_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Product surface', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/pages/payment">Open payment page</a><a class="eden-button secondary" href="/collections/black-card">Black Card details</a></div></section>
<section class="eden-section eden-proof-board" id="approval-references"><div class="eden-section-head"><div><p class="eden-eyebrow">Approved Style</p><h2>Built from the approved black/pink boards</h2></div><p>These source boards stay visible in the theme as the visual contract for GPT, Xyla, and future automation batches.</p></div><div class="eden-reference-grid"><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-desktop-home-reference.png?v=1781419565" alt="Approved desktop homepage reference"><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-mobile-full-reference.png?v=1781419576" alt="Approved full mobile reference"><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-ui-mobile-roster.png?v=1781419417" alt="Approved roster reference"></div></section>
{% schema %}
{"name":"Eden Shopify home","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Eden Skye Studios"},{"type":"text","id":"heading","label":"Heading","default":"Beauty. Influence. Impact."},{"type":"textarea","id":"subheading","label":"Subheading","default":"A black-card AI model studio and Shopify-ready content engine for ladies, gentlemen, faceless products, video automation, and premium creative commerce."},{"type":"image_picker","id":"hero_image","label":"Hero image"},{"type":"text","id":"hero_fallback_url","label":"Shopify CDN hero image URL"},{"type":"text","id":"primary_label","label":"Primary label","default":"Explore Ladies"},{"type":"url","id":"primary_link","label":"Primary link"},{"type":"text","id":"secondary_label","label":"Secondary label","default":"Black Card"},{"type":"url","id":"secondary_link","label":"Secondary link"}],"blocks":[{"type":"female_model","name":"Lady model","settings":[{"type":"text","id":"title","label":"Name","default":"Alexis Voss"},{"type":"textarea","id":"text","label":"Description","default":"Premium editorial model for Black Card content, product stories, and member experiences."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"male_model","name":"Gentleman model","settings":[{"type":"text","id":"title","label":"Name","default":"Dante Cross"},{"type":"textarea","id":"text","label":"Description","default":"Premium male model source for lifestyle, fashion, and video automation drafts."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"faceless_offer","name":"Faceless offer","settings":[{"type":"text","id":"title","label":"Title","default":"Noir Diary"},{"type":"textarea","id":"text","label":"Description","default":"Faceless luxury content lane for short-form storytelling and social automation."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"product_offer","name":"Product offer","settings":[{"type":"text","id":"title","label":"Title","default":"Black Card"},{"type":"textarea","id":"text","label":"Description","default":"Premium membership surface. Live checkout activation remains approval gated."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Eden Shopify home"}]}
{% endschema %}

<section class="eden-hero eden-hero-approved">
  <div class="eden-hero-inner">
    <div>
      <p class="eden-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
      <div class="eden-hero-actions"><a class="eden-button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a><a class="eden-button secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a></div>
      <div class="eden-hero-proof"><span>Model portfolios</span><span>Premium media</span><span>Black Card</span><span>Private closet</span></div>
    </div>
    <div class="eden-visual-panel">{% if section.settings.hero_image != blank %}{{ section.settings.hero_image | image_url: width: 1400 | image_tag: loading: 'eager', alt: section.settings.heading }}{% elsif section.settings.hero_fallback_url != blank %}<img src="{{ section.settings.hero_fallback_url | escape }}" alt="{{ section.settings.heading | escape }}" loading="eager">{% endif %}</div>
  </div>
</section>
{% assign female_blocks = section.blocks | where: 'type', 'female_model' %}{% assign male_blocks = section.blocks | where: 'type', 'male_model' %}{% assign faceless_blocks = section.blocks | where: 'type', 'faceless_offer' %}{% assign product_blocks = section.blocks | where: 'type', 'product_offer' %}
<section class="eden-section eden-difference"><div class="eden-section-head"><div><p class="eden-eyebrow">The Eden Skye Difference</p><h2>Digital modeling with a private-club edge.</h2></div><p>We build polished model worlds, premium media drops, and member experiences designed for beauty, influence, and impact.</p></div><div class="eden-proof-grid"><article><strong>Elite Talent</strong><span>Digital models with clear visual identities and dedicated portfolio pages.</span></article><article><strong>Premium Media</strong><span>Cinematic galleries, member-only looks, and campaign-ready creative.</span></article><article><strong>Black Card</strong><span>A private access layer for galleries, drops, and Eden's Closet.</span></article><article><strong>Brand Ready</strong><span>Creator production and partnership surfaces for polished launches.</span></article></div></section>
<section class="eden-section" id="ladies"><div class="eden-section-head"><div><p class="eden-eyebrow">Ladies</p><h2>Choose your model</h2></div><p>Select a model to view her portfolio, available media styles, and Black Card access options.</p></div><div class="eden-grid">{% for block in female_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'View portfolio', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/collections/ladies">View all ladies</a><a class="eden-button secondary" href="/pages/payment">Join Black Card</a></div></section>
<section class="eden-section eden-feature-band" id="gentlemen"><div class="eden-section-head"><div><p class="eden-eyebrow">Gentlemen</p><h2>Men's model portfolio</h2></div><p>Browse premium male models for lifestyle, editorial, creator campaigns, and private media access.</p></div><div class="eden-grid">{% for block in male_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'View portfolio', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/collections/gentlemen">View all gentlemen</a><a class="eden-button secondary" href="/pages/payment">Join Black Card</a></div></section>
<section class="eden-section" id="faceless"><div class="eden-section-head"><div><p class="eden-eyebrow">Faceless</p><h2>Content creator media</h2></div><p>Premium faceless media concepts for luxury visuals, product storytelling, and short-form creator content.</p></div><div class="eden-product-list">{% for block in faceless_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Explore media', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/collections/faceless-content">View faceless media</a><a class="eden-button secondary" href="/pages/payment">Join Black Card</a></div></section>
<section class="eden-section eden-feature-band" id="black-card"><div class="eden-section-head"><div><p class="eden-eyebrow">Membership</p><h2>Black Card access</h2></div><p>Join Black Card to unlock private model media, premium drops, Eden's Closet access, and member-only digital experiences.</p></div><div class="eden-product-list">{% for block in product_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Membership', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div><div class="eden-page-actions"><a class="eden-button" href="/pages/payment">Open payment page</a><a class="eden-button secondary" href="/pages/edens-closet">Preview Eden's Closet</a></div></section>
<section class="eden-section eden-editorial-split"><div><p class="eden-eyebrow">Creator Production</p><h2>Built for polished launches.</h2><p>Editorial model portfolios, premium content sets, faceless media concepts, and brand partnership assets live in one luxury storefront.</p><div class="eden-page-actions"><a class="eden-button" href="/pages/model-portfolio">Explore portfolio hub</a><a class="eden-button secondary" href="/pages/contact">Partner with Eden Skye</a></div></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-desktop-home-reference.png?v=1781419565" alt="Eden Skye creator production reference"></section>
<section class="eden-section eden-pwa-preview"><div><p class="eden-eyebrow">Eden Skye App</p><h2>Your private studio, in your pocket.</h2><p>Preview the mobile member experience for model discovery, private media, Eden's Closet, messages, and Black Card access.</p><div class="eden-page-actions"><a class="eden-button" href="/pages/pwa-app">Preview the app</a><a class="eden-button secondary" href="/account/login">Member log in</a></div></div><div class="eden-phone-row"><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-ui-mobile-home.png?v=1781419405" alt="Eden Skye mobile home preview"><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-ui-mobile-roster.png?v=1781419417" alt="Eden Skye mobile roster preview"></div></section>
{% schema %}
{"name":"Eden Shopify home","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Eden Skye Studios"},{"type":"text","id":"heading","label":"Heading","default":"Beauty. Influence. Impact."},{"type":"textarea","id":"subheading","label":"Subheading","default":"A premium digital modeling and content creator agency for model portfolios, private media drops, Black Card membership, and Eden's Closet access."},{"type":"image_picker","id":"hero_image","label":"Hero image"},{"type":"text","id":"hero_fallback_url","label":"Shopify CDN hero image URL"},{"type":"text","id":"primary_label","label":"Primary label","default":"Explore Models"},{"type":"url","id":"primary_link","label":"Primary link"},{"type":"text","id":"secondary_label","label":"Secondary label","default":"Join Black Card"},{"type":"url","id":"secondary_link","label":"Secondary link"}],"blocks":[{"type":"female_model","name":"Lady model","settings":[{"type":"text","id":"title","label":"Name","default":"Alexis Voss"},{"type":"textarea","id":"text","label":"Description","default":"Premium editorial model with private portfolio media and member-only content drops."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"male_model","name":"Gentleman model","settings":[{"type":"text","id":"title","label":"Name","default":"Dante Cross"},{"type":"textarea","id":"text","label":"Description","default":"Premium male model portfolio for lifestyle, editorial, and member media access."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"faceless_offer","name":"Faceless offer","settings":[{"type":"text","id":"title","label":"Title","default":"Noir Rooftop"},{"type":"textarea","id":"text","label":"Description","default":"Luxury faceless content lane for premium digital media."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"product_offer","name":"Product offer","settings":[{"type":"text","id":"title","label":"Title","default":"Black Card"},{"type":"textarea","id":"text","label":"Description","default":"Premium membership for private model media, content drops, and Eden's Closet access."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Eden Shopify home"}]}
{% endschema %}

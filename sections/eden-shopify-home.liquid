<section class="eden-hero"><div class="eden-hero-inner"><div><p class="eden-eyebrow">{{ section.settings.eyebrow }}</p><h1>{{ section.settings.heading }}</h1><p>{{ section.settings.subheading }}</p><div class="eden-hero-actions"><a class="eden-button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a><a class="eden-button secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a></div></div><div class="eden-visual-panel">{% if section.settings.hero_image != blank %}{{ section.settings.hero_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: section.settings.heading }}{% elsif section.settings.hero_fallback_url != blank %}<img src="{{ section.settings.hero_fallback_url | escape }}" alt="{{ section.settings.heading | escape }}" loading="eager">{% else %}<div class="eden-visual-placeholder"><div><p class="eden-eyebrow">Approved image slot</p><strong>Upload Eden Skye hero</strong></div></div>{% endif %}</div></div></section>
{% assign female_blocks = section.blocks | where: 'type', 'female_model' %}{% assign male_blocks = section.blocks | where: 'type', 'male_model' %}{% assign faceless_blocks = section.blocks | where: 'type', 'faceless_offer' %}{% assign product_blocks = section.blocks | where: 'type', 'product_offer' %}
<section class="eden-section" id="ladies"><div class="eden-section-head"><div><p class="eden-eyebrow">Ladies</p><h2>Ladies of Eden Skye</h2></div><p>Ten approved Eden Skye ladies for premium model discovery, Shopify content, Xyla video drafts, Black Card experiences, and social campaigns.</p></div><div class="eden-grid">{% for block in female_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Lady model', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div></section>
<section class="eden-section eden-feature-band" id="gentlemen"><div class="eden-section-head"><div><p class="eden-eyebrow">Gentlemen</p><h2>Gentlemen of Eden Skye</h2></div><p>Five approved Eden Skye gentlemen for premium lifestyle, fashion, video scripting, and Shopify offer testing.</p></div><div class="eden-grid">{% for block in male_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Gentleman model', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div></section>
<section class="eden-section" id="faceless"><div class="eden-section-head"><div><p class="eden-eyebrow">Faceless</p><h2>Content engines</h2></div><p>Faceless content lanes for Xyla AI, Shopify product storytelling, short-form video, and social draft automation.</p></div><div class="eden-product-list">{% for block in faceless_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Faceless lane', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div></section>
<section class="eden-section eden-feature-band" id="black-card"><div class="eden-section-head"><div><p class="eden-eyebrow">Shopify ready</p><h2>Products and Black Card</h2></div><p>Draft-safe storefront surfaces for Black Card, model content packs, AI video packages, and productized automation.</p></div><div class="eden-product-list">{% for block in product_blocks %}<div {{ block.shopify_attributes }}>{% render 'eden-card', title: block.settings.title, text: block.settings.text, tag: 'Product draft', image: block.settings.image, fallback_image_url: block.settings.fallback_image_url, url: block.settings.link %}</div>{% endfor %}</div></section>
{% schema %}
{"name":"Eden Shopify home","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Eden Skye Studios"},{"type":"text","id":"heading","label":"Heading","default":"Beauty. Influence. Impact."},{"type":"textarea","id":"subheading","label":"Subheading","default":"A black-card AI model studio and Shopify-ready content engine for women, men, faceless products, video automation, and premium creative commerce."},{"type":"image_picker","id":"hero_image","label":"Hero image"},{"type":"text","id":"hero_fallback_url","label":"Shopify CDN hero image URL"},{"type":"text","id":"primary_label","label":"Primary label","default":"Explore models"},{"type":"url","id":"primary_link","label":"Primary link"},{"type":"text","id":"secondary_label","label":"Secondary label","default":"Black Card"},{"type":"url","id":"secondary_link","label":"Secondary link"}],"blocks":[{"type":"female_model","name":"Female model","settings":[{"type":"text","id":"title","label":"Name","default":"Alexis Voss"},{"type":"textarea","id":"text","label":"Description","default":"Premium editorial model for Black Card content, product stories, and member experiences."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"male_model","name":"Male model","settings":[{"type":"text","id":"title","label":"Name","default":"Dante Cross"},{"type":"textarea","id":"text","label":"Description","default":"Premium male model source for lifestyle, fashion, and video automation drafts."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"faceless_offer","name":"Faceless offer","settings":[{"type":"text","id":"title","label":"Title","default":"Noir Diary"},{"type":"textarea","id":"text","label":"Description","default":"Faceless luxury content lane for short-form storytelling and social automation."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]},{"type":"product_offer","name":"Product offer","settings":[{"type":"text","id":"title","label":"Title","default":"Black Card"},{"type":"textarea","id":"text","label":"Description","default":"Draft-safe premium membership surface. Live payment activation remains approval gated."},{"type":"image_picker","id":"image","label":"Approved source image"},{"type":"text","id":"fallback_image_url","label":"Shopify CDN fallback image URL"},{"type":"url","id":"link","label":"Link"}]}],"presets":[{"name":"Eden Shopify home"}]}
{% endschema %}

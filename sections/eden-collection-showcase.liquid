{% liquid
  assign handle = collection.handle
  assign title = collection.title
%}
<section class="eden-collection eden-showcase">
  <p class="eden-eyebrow">Eden Skye Studios</p>
  <h1>{{ title }}</h1>
  {% if collection.description != blank %}<div class="eden-richtext">{{ collection.description }}</div>{% endif %}
  {% if handle == 'ladies' or handle == 'female-models' %}
    <div class="eden-collection-hero"><div><p class="eden-eyebrow">Approved Ladies</p><h2>Premium AI model roster</h2><p>Ten approved Eden Skye ladies built for Black Card, Shopify, Xyla video drafts, model portfolios, and social automation.</p><div class="eden-page-actions"><a class="eden-button" href="/pages/model-portfolio">View model portfolio</a><a class="eden-button secondary" href="/pages/payment">Black Card access</a></div></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-closeup-night-lounge.png?v=1781419435" alt="Approved Eden Skye lady model"></div>
    <div class="eden-grid eden-showcase-grid">
      {% render 'eden-card', title: 'Alexis Voss', text: 'Signature brunette Black Card model for premium content, product storytelling, and member discovery.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-closeup-night-lounge.png?v=1781419435', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Luna Moretti', text: 'Luxury lounge and nightlife model for cinematic Shopify stories and short-form commerce.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-portrait-black-pink.png?v=1781419459', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Sienna Cole', text: 'Neon-glam model for Xyla-ready videos, Black Card campaigns, and social drafts.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-brunette-portrait-neon.png?v=1781419527', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Eden Skye', text: 'Flagship Eden Skye face for luxury AI model studio branding and hero creative.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-brunette-fullbody-black.png?v=1781419550', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Mila Stone', text: 'Full-body wardrobe and closet model for premium styling, fashion, and member content.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-fullbody-neon-closet.png?v=1781419447', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Aria Noir', text: 'Nightlife and fashion model for premium launch creative.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-06-aria-noir.jpg?v=1781309068', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Nova Lux', text: 'Modern premium creator model for visual hooks, product pages, and ad concepts.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-07-nova-lux.jpg?v=1781309076', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Valentina Rose', text: 'Blonde glam model for premium lifestyle, style, and concierge content.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-blonde-black-neon.png?v=1781419488', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Serena Vail', text: 'Blonde evening model for premium visual storytelling and campaign creative.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-blonde-evening-model.png?v=1781419539', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Isla Monroe', text: 'Redhead fashion model for boutique, social, and Black Card drafts.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-10-redhead-isla-monroe.png?v=1781416374', url: '/pages/model-portfolio' %}
    </div>
  {% elsif handle == 'gentlemen' or handle == 'male-models' %}
    <div class="eden-collection-hero"><div><p class="eden-eyebrow">Approved Gentlemen</p><h2>Premium male model roster</h2><p>Five gentlemen for fashion, lifestyle, Black Card, product storytelling, and Xyla-ready content automation.</p><div class="eden-page-actions"><a class="eden-button" href="/pages/model-portfolio">View portfolio</a><a class="eden-button secondary" href="/pages/payment">Black Card access</a></div></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-01-dante-cross.jpg?v=1781309108" alt="Eden Skye gentleman model"></div>
    <div class="eden-grid eden-showcase-grid">
      {% render 'eden-card', title: 'Dante Cross', text: 'Luxury male model for fashion, nightlife, and lifestyle commerce.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-01-dante-cross.jpg?v=1781309108', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Jax Rhodes', text: 'Bold male model for fitness-luxury and social creative.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-02-jax-rhodes.jpg?v=1781309117', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Roman Kade', text: 'Premium male model for editorial and Shopify product storytelling.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-03-roman-kade.jpg?v=1781309142', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Kai Voss', text: 'Modern male model for video scripts, fashion offers, and lifestyle content.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-04-kai-voss.jpg?v=1781309134', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Marco Slate', text: 'Upscale male model for concierge content and campaign drafts.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-05-marco-slate.jpg?v=1781309149', url: '/pages/model-portfolio' %}
    </div>
  {% elsif handle == 'faceless-content' %}
    <div class="eden-collection-hero"><div><p class="eden-eyebrow">Faceless Content</p><h2>Automation-ready scenes</h2><p>Luxury environments for Xyla AI, product videos, faceless short-form content, and premium creative automation.</p><div class="eden-page-actions"><a class="eden-button" href="/pages/eden-admin">Open hidden admin</a><a class="eden-button secondary" href="/pages/payment">Black Card access</a></div></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-walkin-closet-environment.png?v=1781419503" alt="Eden Skye closet environment"></div><div class="eden-product-list">{% render 'eden-card', title: 'Luxury Suite', text: 'High-end bedroom and lounge source for product storytelling and cinematic drafts.', tag: 'Faceless engine', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-luxury-suite-environment.png?v=1781419515', url: '/pages/eden-admin' %}{% render 'eden-card', title: 'Noir Rooftop', text: 'Dark luxury rooftop environment for high-retention social and launch content.', tag: 'Faceless engine', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-rooftop-night-environment.png?v=1781419470', url: '/pages/eden-admin' %}{% render 'eden-card', title: 'Eden Closet', text: 'Walk-in closet source for wardrobe, styling, and member content workflows.', tag: 'Faceless engine', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-walkin-closet-environment.png?v=1781419503', url: '/pages/eden-admin' %}</div>
  {% elsif handle == 'black-card' %}
    <div class="eden-blackcard-layout"><div><p class="eden-eyebrow">Premium Access</p><h2>Black Card</h2><p>Private access for model content, AI video scripts, Xyla-ready media packs, approval workflows, and concierge-style creative automation.</p><ul><li>Model portfolio access</li><li>Image and video content batches</li><li>Creator approval pipeline</li><li>Shopify/Xyla automation handoff</li></ul><a class="eden-button" href="/pages/payment">Open payment page</a></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-product-01-black-card.jpg?v=1781309179" alt="Eden Skye Black Card"></div>
  {% else %}
    <div class="eden-grid">{% paginate collection.products by 20 %}{% for product in collection.products %}{% render 'eden-card', title: product.title, text: product.price | money, tag: 'Shopify product', image: product.featured_image, url: product.url %}{% else %}<article class="eden-card"><div class="eden-card-media"></div><div class="eden-card-body"><h3>Collection product slot</h3><p>Add Shopify products to this collection when ready.</p><span class="eden-card-tag">Draft safe</span></div></article>{% endfor %}{{ paginate | default_pagination }}{% endpaginate %}</div>
  {% endif %}
</section>
{% schema %}{"name":"Eden collection showcase","settings":[]}{% endschema %}

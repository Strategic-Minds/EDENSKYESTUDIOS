{% liquid
  assign handle = collection.handle
  assign title = collection.title
%}
<section class="eden-collection eden-showcase">
  <p class="eden-eyebrow">Eden Skye Studios</p>
  <h1>{{ title }}</h1>
  {% if collection.description != blank %}<div class="eden-richtext">{{ collection.description }}</div>{% endif %}
  {% if handle == 'ladies' or handle == 'female-models' %}
    <div class="eden-collection-hero"><div><p class="eden-eyebrow">Ladies</p><h2>Choose a model</h2><p>Explore premium digital model portfolios. Select any model to view her profile, preview gallery, and Black Card access options.</p><div class="eden-page-actions"><a class="eden-button" href="/pages/model-portfolio">View portfolio hub</a><a class="eden-button secondary" href="/pages/payment">Join Black Card</a></div></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-closeup-night-lounge.png?v=1781419435" alt="Eden Skye lady model"></div>
    <div class="eden-grid eden-showcase-grid">
      {% render 'eden-card', title: 'Alexis Voss', text: 'Signature brunette model with private editorial media and premium galleries.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-closeup-night-lounge.png?v=1781419435', url: '/pages/model-alexis-voss' %}
      {% render 'eden-card', title: 'Luna Moretti', text: 'Luxury nightlife and lounge model with cinematic portfolio media.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-portrait-black-pink.png?v=1781419459', url: '/pages/model-luna-moretti' %}
      {% render 'eden-card', title: 'Sienna Cole', text: 'Neon-glam model for premium creator media and private galleries.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-brunette-portrait-neon.png?v=1781419527', url: '/pages/model-sienna-cole' %}
      {% render 'eden-card', title: 'Eden Skye', text: 'Flagship Eden Skye model with signature black and pink styling.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-brunette-fullbody-black.png?v=1781419550', url: '/pages/model-eden-skye' %}
      {% render 'eden-card', title: 'Mila Stone', text: 'Full-body wardrobe and closet model for style-led member media.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-fullbody-neon-closet.png?v=1781419447', url: '/pages/model-mila-stone' %}
      {% render 'eden-card', title: 'Aria Noir', text: 'Nightlife and fashion model with premium launch visuals.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-06-aria-noir.jpg?v=1781309068', url: '/pages/model-aria-noir' %}
      {% render 'eden-card', title: 'Nova Lux', text: 'Modern luxury model with fashion sets and portfolio content.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-07-nova-lux.jpg?v=1781309076', url: '/pages/model-nova-lux' %}
      {% render 'eden-card', title: 'Valentina Rose', text: 'Blonde glam model with lifestyle media and style shoots.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-blonde-black-neon.png?v=1781419488', url: '/pages/model-valentina-rose' %}
      {% render 'eden-card', title: 'Serena Vail', text: 'Blonde evening model with premium visual storytelling.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-blonde-evening-model.png?v=1781419539', url: '/pages/model-serena-vail' %}
      {% render 'eden-card', title: 'Isla Monroe', text: 'Redhead fashion model for boutique and member-only drops.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-10-redhead-isla-monroe.png?v=1781416374', url: '/pages/model-isla-monroe' %}
    </div>
  {% elsif handle == 'gentlemen' or handle == 'male-models' %}
    <div class="eden-collection-hero"><div><p class="eden-eyebrow">Gentlemen</p><h2>Men's model portfolio</h2><p>Browse premium male model profiles for lifestyle, editorial, and private Black Card media.</p><div class="eden-page-actions"><a class="eden-button" href="/pages/model-portfolio">View portfolio hub</a><a class="eden-button secondary" href="/pages/payment">Join Black Card</a></div></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-01-dante-cross.jpg?v=1781309108" alt="Eden Skye gentleman model"></div>
    <div class="eden-grid eden-showcase-grid">
      {% render 'eden-card', title: 'Dante Cross', text: 'Luxury male model for fashion, nightlife, and lifestyle media.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-01-dante-cross.jpg?v=1781309108', url: '/pages/model-dante-cross' %}
      {% render 'eden-card', title: 'Jax Rhodes', text: 'Bold male model for fitness-luxury and editorial shoots.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-02-jax-rhodes.jpg?v=1781309117', url: '/pages/model-jax-rhodes' %}
      {% render 'eden-card', title: 'Roman Kade', text: 'Premium male model for editorial and fashion media.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-03-roman-kade.jpg?v=1781309142', url: '/pages/model-roman-kade' %}
      {% render 'eden-card', title: 'Kai Voss', text: 'Modern male model for lifestyle and premium content campaigns.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-04-kai-voss.jpg?v=1781309134', url: '/pages/model-kai-voss' %}
      {% render 'eden-card', title: 'Marco Slate', text: 'Upscale male model for member-only campaign drops.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-05-marco-slate.jpg?v=1781309149', url: '/pages/model-marco-slate' %}
    </div>
  {% elsif handle == 'faceless-content' %}
    <div class="eden-collection-hero"><div><p class="eden-eyebrow">Faceless Content</p><h2>Premium media worlds</h2><p>Luxury scenes and visual concepts for faceless creator content, lifestyle storytelling, and product media.</p><div class="eden-page-actions"><a class="eden-button" href="/pages/payment">Join Black Card</a><a class="eden-button secondary" href="/pages/edens-closet">Preview Eden's Closet</a></div></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-walkin-closet-environment.png?v=1781419503" alt="Eden Skye closet environment"></div><div class="eden-product-list">{% render 'eden-card', title: 'Luxury Suite', text: 'High-end bedroom and lounge visuals for cinematic media.', tag: 'Media world', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-luxury-suite-environment.png?v=1781419515', url: '/pages/payment' %}{% render 'eden-card', title: 'Noir Rooftop', text: 'Dark luxury rooftop environment for premium visual content.', tag: 'Media world', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-rooftop-night-environment.png?v=1781419470', url: '/pages/payment' %}{% render 'eden-card', title: 'Eden Closet', text: 'Walk-in closet source for wardrobe, styling, and member content.', tag: 'Member area', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-walkin-closet-environment.png?v=1781419503', url: '/pages/edens-closet' %}</div>
  {% elsif handle == 'black-card' %}
    <div class="eden-blackcard-layout"><div><p class="eden-eyebrow">Premium Access</p><h2>Black Card</h2><p>Private access for model portfolios, premium media drops, member-only galleries, and Eden's Closet.</p><ul><li>Model portfolio access</li><li>Private media drops</li><li>Eden's Closet member area</li><li>Early access to new creator content</li></ul><a class="eden-button" href="/pages/payment">Open payment page</a></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-product-01-black-card.jpg?v=1781309179" alt="Eden Skye Black Card"></div>
  {% else %}
    <div class="eden-grid">{% paginate collection.products by 20 %}{% for product in collection.products %}{% render 'eden-card', title: product.title, text: product.price | money, tag: 'Shopify product', image: product.featured_image, url: product.url %}{% else %}<article class="eden-card"><div class="eden-card-media"></div><div class="eden-card-body"><h3>Collection product slot</h3><p>Add Shopify products to this collection when ready.</p><span class="eden-card-tag">Draft safe</span></div></article>{% endfor %}{{ paginate | default_pagination }}{% endpaginate %}</div>
  {% endif %}
</section>
{% schema %}{"name":"Eden collection showcase","settings":[]}{% endschema %}

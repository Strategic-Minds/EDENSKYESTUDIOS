{% liquid
  assign handle = collection.handle
  assign title = collection.title
%}
<section class="eden-collection eden-showcase">
  <p class="eden-eyebrow">Eden Skye Studios</p>
  <h1>{{ title }}</h1>
  {% if collection.description != blank %}<div class="eden-richtext">{{ collection.description }}</div>{% endif %}

  {% if handle == 'ladies' or handle == 'female-models' %}
    <div class="eden-page-actions"><a class="eden-button" href="/pages/model-portfolio">View model portfolio</a><a class="eden-button secondary" href="/pages/payment">Black Card access</a></div>
    <div class="eden-grid eden-showcase-grid">
      {% render 'eden-card', title: 'Alexis Voss', text: 'Black Card editorial model for premium content, product storytelling, and member discovery.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-01-alexis-voss.jpg?v=1781309018', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Luna Moretti', text: 'Luxury lifestyle model for cinematic content, fashion, and short-form commerce.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-02-luna-moretti.jpg?v=1781309028', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Sienna Cole', text: 'Neon-glam social model for Xyla-ready video drafts and Black Card experiences.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-03-sienna-cole.jpg?v=1781309035', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Eden Skye', text: 'Signature brand model and flagship face of Eden Skye Studios.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-04-eden-skye.jpg?v=1781309043', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Mila Stone', text: 'High-glam editorial model for Shopify product stories and social campaigns.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-05-mila-stone.jpg?v=1781309052', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Aria Noir', text: 'Nightlife and fashion model for premium launch creative.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-06-aria-noir.jpg?v=1781309068', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Nova Lux', text: 'Modern luxury model for visual hooks, product pages, and ad concepts.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-07-nova-lux.jpg?v=1781309076', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Valentina Rose', text: 'Blonde glam model for premium lifestyle, style, and concierge content.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-08-blonde-valentina-rose.png?v=1781416349', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Serena Vail', text: 'Blonde luxury model for premium visual storytelling and campaigns.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-09-blonde-serena-vail.png?v=1781416361', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Isla Monroe', text: 'Redhead fashion model for boutique, social, and Black Card drafts.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-10-redhead-isla-monroe.png?v=1781416374', url: '/pages/model-portfolio' %}
    </div>
  {% elsif handle == 'gentlemen' or handle == 'male-models' %}
    <div class="eden-page-actions"><a class="eden-button" href="/pages/model-portfolio">View model portfolio</a><a class="eden-button secondary" href="/pages/payment">Black Card access</a></div>
    <div class="eden-grid eden-showcase-grid">
      {% render 'eden-card', title: 'Dante Cross', text: 'Luxury male model for fashion, nightlife, and lifestyle commerce.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-01-dante-cross.jpg?v=1781309108', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Jax Rhodes', text: 'Bold male model for fitness-luxury and social creative.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-02-jax-rhodes.jpg?v=1781309117', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Roman Kade', text: 'Premium male model for editorial and Shopify product storytelling.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-03-roman-kade.jpg?v=1781309142', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Kai Voss', text: 'Modern male model for video scripts, fashion offers, and lifestyle content.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-04-kai-voss.jpg?v=1781309134', url: '/pages/model-portfolio' %}
      {% render 'eden-card', title: 'Marco Slate', text: 'Upscale male model for concierge content and campaign drafts.', tag: 'Gentleman model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-05-marco-slate.jpg?v=1781309149', url: '/pages/model-portfolio' %}
    </div>
  {% elsif handle == 'faceless-content' %}
    <div class="eden-page-actions"><a class="eden-button" href="/pages/eden-admin">Open approval control plane</a><a class="eden-button secondary" href="/pages/payment">Black Card access</a></div>
    <div class="eden-product-list">
      {% render 'eden-card', title: 'Morning Atelier', text: 'Faceless luxury morning routine and product storytelling lane for Xyla AI.', tag: 'Faceless engine', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-faceless-01-morning-atelier.jpg?v=1781309157', url: '/pages/eden-admin' %}
      {% render 'eden-card', title: 'Noir Diary', text: 'Dark luxury short-form video lane for high-retention social content.', tag: 'Faceless engine', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-faceless-02-noir-diary.jpg?v=1781309163', url: '/pages/eden-admin' %}
      {% render 'eden-card', title: 'Glass Studio', text: 'Clean premium product and lifestyle lane for automation-ready content.', tag: 'Faceless engine', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-faceless-03-glass-studio.jpg?v=1781309171', url: '/pages/eden-admin' %}
    </div>
  {% elsif handle == 'black-card' %}
    <div class="eden-blackcard-layout">
      <div><h2>Black Card Access</h2><p>Premium access for model content, AI video scripts, Xyla-ready media packs, private content approval, and concierge-style creative automation.</p><ul><li>Model portfolio access</li><li>Image and video content batches</li><li>Creator approval pipeline</li><li>Shopify/Xyla automation handoff</li></ul><a class="eden-button" href="/pages/payment">Open payment page</a></div>
      <img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-product-01-black-card.jpg?v=1781309179" alt="Eden Skye Black Card">
    </div>
  {% else %}
    <div class="eden-grid">{% paginate collection.products by 20 %}{% for product in collection.products %}{% render 'eden-card', title: product.title, text: product.price | money, tag: 'Shopify product', image: product.featured_image, url: product.url %}{% else %}<article class="eden-card"><div class="eden-card-media"></div><div class="eden-card-body"><h3>Collection product slot</h3><p>Add Shopify products to this collection when ready.</p><span class="eden-card-tag">Draft safe</span></div></article>{% endfor %}{{ paginate | default_pagination }}{% endpaginate %}</div>
  {% endif %}
</section>
{% schema %}{"name":"Eden collection showcase","settings":[]}{% endschema %}

<section class="eden-product"><div class="eden-visual-panel">{% if product.featured_image %}{{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: product.title }}{% else %}<div class="eden-visual-placeholder"><div><p class="eden-eyebrow">Product image slot</p><strong>{{ product.title }}</strong></div></div>{% endif %}</div><div><p class="eden-eyebrow">Eden Skye product</p><h1>{{ product.title }}</h1><div>{{ product.description }}</div>{% form 'product', product %}<input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">{% if product.has_only_default_variant == false %}<label for="ProductSelect">Option</label><select id="ProductSelect" name="id">{% for variant in product.variants %}<option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>{{ variant.title }} - {{ variant.price | money }}</option>{% endfor %}</select>{% endif %}<button class="eden-button" type="submit" {% unless product.available %}disabled{% endunless %}>{% if product.available %}Add to cart{% else %}Unavailable{% endif %}</button>{% endform %}<p class="eden-card-tag">Live payment activation stays merchant controlled inside Shopify.</p></div></section>{% schema %}{"name":"Main product","settings":[]}{% endschema %}

<section class="eden-page eden-experience-page">
  {% if page.handle == 'payment' %}
    <p class="eden-eyebrow">Secure Access</p><h1>Black Card Payment</h1><div class="eden-blackcard-layout"><div><p>Black Card is the premium access layer for Eden Skye Studios content, model discovery, AI video workflows, and private creative automation.</p><div class="eden-price">$49<span>/month draft</span></div><p class="eden-muted-note">Payment activation remains gated until final Shopify checkout approval. This page is ready for the product checkout link.</p><a class="eden-button" href="/collections/black-card">Review Black Card</a></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-product-01-black-card.jpg?v=1781309179" alt="Black Card"></div>
  {% elsif page.handle == 'model-portfolio' %}
    <p class="eden-eyebrow">Model Portfolio</p><h1>Alexis Voss Portfolio</h1><div class="eden-profile-layout"><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-01-alexis-voss.jpg?v=1781309018" alt="Alexis Voss"><div><h2>Premium editorial model</h2><p>Black Card editorial model for premium content, product storytelling, gallery campaigns, videos, and member discovery.</p><div class="eden-stat-grid"><span>5'8 editorial</span><span>Fashion</span><span>AI video</span><span>Shopify content</span></div><a class="eden-button" href="/pages/payment">Work with this model</a></div></div><div class="eden-grid eden-showcase-grid">{% render 'eden-card', title: 'Valentina Rose', text: 'Blonde lifestyle and concierge content.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-08-blonde-valentina-rose.png?v=1781416349', url: '/pages/payment' %}{% render 'eden-card', title: 'Serena Vail', text: 'Blonde luxury campaign model.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-09-blonde-serena-vail.png?v=1781416361', url: '/pages/payment' %}{% render 'eden-card', title: 'Isla Monroe', text: 'Redhead fashion and social creative.', tag: 'Lady model', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-female-10-redhead-isla-monroe.png?v=1781416374', url: '/pages/payment' %}</div>

 '/pages/payment' %}{% render 'eden-card', title: 'Mila Stone', text: 'Full-body closet styling source for wardrobe and viewer workflows.', tag: 'Portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-fullbody-neon-closet.png?v=1781419447', url: '/pages/payment' %}{% render 'eden-card', title: 'Sienna Cole', text: 'Hot-pink neon portrait for social and video drafts.', tag: 'Portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-brunette-portrait-neon.png?v=1781419527', url: '/pages/payment' %}</div>

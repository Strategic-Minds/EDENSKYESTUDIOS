<section class="eden-page eden-experience-page">
  {% if page.handle == 'payment' %}
    <p class="eden-eyebrow">Black Card Access</p><h1>Unlock Eden Skye</h1><div class="eden-blackcard-layout"><div><p>Join Black Card for private model portfolios, member-only media drops, and access to Eden's Closet.</p><div class="eden-price">$49<span>/month launch offer</span></div><div class="eden-payment-stack"><article><strong>Step 1</strong><span>Choose a model or media experience.</span></article><article><strong>Step 2</strong><span>Join Black Card using the secure Shopify checkout link.</span></article><article><strong>Step 3</strong><span>Access Eden's Closet and member content after payment.</span></article></div><a class="eden-button" href="/collections/black-card">Select Black Card</a><a class="eden-button secondary" href="/pages/edens-closet">Preview Eden's Closet</a></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-product-01-black-card.jpg?v=1781309179" alt="Black Card"></div>
  {% elsif page.handle == 'edens-closet' %}
    <p class="eden-eyebrow">Member Access</p><h1>Eden's Closet</h1><div class="eden-blackcard-layout"><div><p>Eden's Closet is the private member area for wardrobe looks, premium model visuals, styling scenes, and locked media drops.</p><div class="eden-payment-stack"><article><strong>Status</strong><span>Black Card members get access after checkout.</span></article><article><strong>Inside</strong><span>Wardrobe scenes, model looks, favorites, and private galleries.</span></article><article><strong>Access</strong><span>Log in with your Shopify customer account after payment.</span></article></div><a class="eden-button" href="/pages/payment">Join Black Card</a><a class="eden-button secondary" href="/account/login">Member Log In</a></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-walkin-closet-environment.png?v=1781419503" alt="Eden's Closet"></div>
  {% elsif is_model_page %}
    <p class="eden-eyebrow">{{ model_role }}</p><h1>{{ model_name }}</h1><div class="eden-profile-layout"><img src="{{ model_image }}" alt="{{ model_name | escape }}"><div><h2>Portfolio</h2><p>{{ model_bio }}</p><div class="eden-stat-grid"><span>Private gallery</span><span>Member drops</span><span>Digital media</span><span>Black Card</span></div><a class="eden-button" href="/pages/payment">Unlock this model</a></div></div><div class="eden-section-head eden-inline-head"><div><p class="eden-eyebrow">Gallery Preview</p><h2>Selected looks</h2></div><p>Preview the model's visual world. Full galleries unlock through Black Card.</p></div><div class="eden-reference-grid"><img src="{{ model_image }}" alt="{{ model_name | escape }} primary look"><img src="{{ model_gallery_2 }}" alt="{{ model_name | escape }} gallery look"><img src="{{ model_gallery_3 }}" alt="{{ model_name | escape }} environment look"></div><div class="eden-page-actions"><a class="eden-button" href="/pages/payment">Continue to payment</a><a class="eden-button secondary" href="/collections/ladies">Back to models</a></div>
  {% elsif page.handle == 'model-portfolio' %}
    <p class="eden-eyebrow">Model Portfolio</p><h1>Explore Eden Skye Models</h1><p class="eden-richtext">Select any model card to open a dedicated portfolio page. Black Card unlocks private media and Eden's Closet access.</p><div class="eden-grid eden-showcase-grid">{% render 'eden-card', title: 'Alexis Voss', text: 'Signature brunette model with private editorial media.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-closeup-night-lounge.png?v=1781419435', url: '/pages/model-alexis-voss' %}{% render 'eden-card', title: 'Valentina Rose', text: 'Blonde glam model with lifestyle and style shoots.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-blonde-black-neon.png?v=1781419488', url: '/pages/model-valentina-rose' %}{% render 'eden-card', title: 'Dante Cross', text: 'Luxury male model for fashion and lifestyle media.', tag: 'View portfolio', fallback_image_url: 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-skye-male-01-dante-cross.jpg?v=1781309108', url: '/pages/model-dante-cross' %}</div><div class="eden-page-actions"><a class="eden-button" href="/collections/ladies">Ladies</a><a class="eden-button secondary" href="/collections/gentlemen">Gentlemen</a></div>
  {% elsif page.handle == 'eden-admin' %}
    <p class="eden-eyebrow">Hidden Admin</p><h1>Eden Skye Admin</h1><div class="eden-admin-hero"><div><h2>Approval chat and media control plane</h2><p>Private approval workspace for image review, video packets, content drafts, model manifests, Drive source files, and storefront release gates.</p><div class="eden-admin-chat"><div class="eden-chat-line user">Jeremy: Review this batch for site approval.</div><div class="eden-chat-line assistant">Eden Admin: I found 15 model assets, 3 media drops, 1 payment gate, and 2 items needing approval.</div><div class="eden-chat-input">Ask Eden Admin to review images, approve content, or prepare a Shopify update...</div></div></div><img src="https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-ui-mobile-roster.png?v=1781419417" alt="Eden Skye admin approval UI reference"></div><div class="eden-admin-grid"><article><span>Images</span><strong>Approval Gallery</strong><p>Approve, reject, or quarantine source images before public use.</p></article><article><span>Video</span><strong>Video Queue</strong><p>Review scripts, avatar packets, reels, and content drafts.</p></article><article><span>Drive</span><strong>Source Truth</strong><p>Track manifests, filenames, and canonical assets.</p></article><article><span>Store</span><strong>Release Gate</strong><p>Approve payment links, product activation, and storefront changes.</p></article></div>
  {% else %}
    <p class="eden-eyebrow">Eden Skye Studios</p><h1>{{ page.title }}</h1><div class="eden-richtext">{{ page.content }}</div>
  {% endif %}
</section>
{% schema %}{"name":"Eden page experience","settings":[]}{% endschema %}

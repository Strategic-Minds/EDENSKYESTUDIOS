{% doc %}
@param {string} title - Card title
@param {string} text - Card supporting text
@param {string} tag - Card category label
@param {image} image - Optional Shopify image picker image
@param {string} fallback_image_url - Optional Shopify CDN image URL
@param {string} url - Optional destination URL
{% enddoc %}
{% liquid
  assign forced_image_url = fallback_image_url
  if forced_image_url == blank
    case title
      when 'Alexis Voss'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-closeup-night-lounge.png?v=1781419435'
      when 'Luna Moretti'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-portrait-black-pink.png?v=1781419459'
      when 'Sienna Cole'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-brunette-portrait-neon.png?v=1781419527'
      when 'Eden Skye'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-brunette-fullbody-black.png?v=1781419550'
      when 'Mila Stone'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-model-fullbody-neon-closet.png?v=1781419447'
      when 'Valentina Rose'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-blonde-black-neon.png?v=1781419488'
      when 'Serena Vail'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-blonde-evening-model.png?v=1781419539'
      when 'Morning Atelier'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-luxury-suite-environment.png?v=1781419515'
      when 'Noir Diary'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-rooftop-night-environment.png?v=1781419470'
      when 'Glass Studio'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-walkin-closet-environment.png?v=1781419503'
      when 'AI Model Content Pack'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-ui-mobile-roster.png?v=1781419417'
      when 'Xyla Video Draft Pack'
        assign forced_image_url = 'https://cdn.shopify.com/s/files/1/0754/8905/0678/files/eden-approved-mobile-full-reference.png?v=1781419576'
    endcase
  endif
%}
{% if url != blank %}<a class="eden-card" href="{{ url }}">{% else %}<article class="eden-card">{% endif %}<div class="eden-card-media">{% if image != blank %}{{ image | image_url: width: 900 | image_tag: loading: 'lazy', alt: title }}{% elsif forced_image_url != blank %}<img src="{{ forced_image_url }}" alt="{{ title | escape }}" loading="lazy">{% endif %}</div><div class="eden-card-body"><h3>{{ title | escape }}</h3><p>{{ text | escape }}</p><span class="eden-card-tag">{{ tag | escape }}</span></div>{% if url != blank %}</a>{% else %}</article>{% endif %}

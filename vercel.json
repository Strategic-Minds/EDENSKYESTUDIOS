{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/eden-media-preview",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/eden-image-generator",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/eden-skye-generator-tick",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/recursive-completion-dry-run",
      "schedule": "30 * * * *"
    }
  ]
}
